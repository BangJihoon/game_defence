# 2️⃣ SkillEngine – 다단히트 + 연쇄 구현

```dart
void executeChainSkill({
  required CharacterComponent caster,
  required SkillData skill,
  required EnemyComponent firstTarget,
  required List<EnemyComponent> allEnemies,
}) {
  final selector = TargetSelector();

  final targets = selector.selectChainTargets(
    firstTarget: firstTarget,
    allEnemies: allEnemies,
    maxTargets: skill.hitCount,
    chainRange: skill.range,
  );

  EnemyComponent? previous;

  for (final target in targets) {
    final damage = damageCalculator.calculate(
      casterAttack: caster.attack,
      targetDefense: target.defense,
      skillMultiplier: skill.multiplier,
      element: skill.element,
      targetElement: target.element,
    );

    target.applyDamage(damage);

    // ⚡ 번개 연결 이펙트
    effectSpawner.spawnLightningChain(
      from: previous?.position ?? caster.position,
      to: target.position,
    );

    feedbackSystem.playHitFeedback(target.position);

    previous = target;
  }
}
```

