# 1️⃣ TargetSelector – 연쇄 타겟 선택

```dart
import 'package:flame/components.dart';

class TargetSelector {
  List<EnemyComponent> selectChainTargets({
    required EnemyComponent firstTarget,
    required List<EnemyComponent> allEnemies,
    required int maxTargets,
    required double chainRange,
  }) {
    final List<EnemyComponent> result = [];
    final Set<EnemyComponent> visited = {};

    EnemyComponent? current = firstTarget;

    while (current != null && result.length < maxTargets) {
      result.add(current);
      visited.add(current);

      EnemyComponent? next;
      double closestDistance = chainRange;

      for (final enemy in allEnemies) {
        if (visited.contains(enemy)) continue;

        final distance =
            current.position.distanceTo(enemy.position);

        if (distance < closestDistance) {
          closestDistance = distance;
          next = enemy;
        }
      }

      current = next;
    }

    return result;
  }
}
```

