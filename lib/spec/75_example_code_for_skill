# ✅ 2️⃣ TempleGame

```dart
import 'package:flame/game.dart';
import 'package:flame/components.dart';
import 'components/character_component.dart';
import 'components/enemy_component.dart';
import 'combat/skill_engine.dart';
import 'combat/damage_calculator.dart';
import 'combat/status_engine.dart';
import 'combat/target_selector.dart';

class TempleGame extends FlameGame {
  late SkillEngine skillEngine;

  @override
  Future<void> onLoad() async {
    skillEngine = SkillEngine(
      damageCalculator: DamageCalculator(),
      statusEngine: StatusEngine(),
      effectSpawner: EffectSpawner(this),
      feedbackSystem: HitFeedbackSystem(this),
    );

    final hero = CharacterComponent(
      position: Vector2(300, 500),
      attack: 200,
      element: ElementType.FIRE,
      game: this,
    );

    final enemy = EnemyComponent(
      position: Vector2(800, 500),
      hp: 1000,
      defense: 50,
      element: ElementType.NATURE,
    );

    add(hero);
    add(enemy);

    // 2초 후 스킬 발동
    Future.delayed(const Duration(seconds: 2), () {
      skillEngine.executeSkill(
        caster: hero,
        skill: SkillData.demoFireSkill(),
        targets: [enemy],
      );
    });
  }
}
```

